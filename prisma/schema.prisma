generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── 工人档案 ────────────────────────────────────────────────────────────────

model Worker {
  id            String       @id
  name          String
  project       String
  phone         String?
  idCard        String?      // 身份证号
  insuranceInfo Json?        // 保险信息 {type, policyNo, expireDate}
  wageType      String?      // "daily" | "monthly" | "piecework"
  wageRate      Float?       // 日薪/月薪/计件单价
  loginPin      String?      // 工人登录PIN（手机后4位/身份证后4位）
  checkIns      CheckIn[]
  reports       Report[]
  corrections   Correction[]
}

// ─── 考勤签到（支持 Geofencing 自动触发） ────────────────────────────────────

model CheckIn {
  id        Int      @id @default(autoincrement())
  workerId  String
  worker    Worker   @relation(fields: [workerId], references: [id])
  project   String
  // Geofencing 字段
  type      String   @default("manual")  // "auto_in" | "auto_out" | "manual"
  gpsLat    Float?
  gpsLng    Float?
  checkOut  DateTime?  // 离场时间
  duration  Int?       // 在场分钟数（签退时写入）
  createdAt DateTime @default(now())
}

// ─── 施工报量 ─────────────────────────────────────────────────────────────────

model Report {
  id            Int          @id @default(autoincrement())
  workerId      String
  worker        Worker       @relation(fields: [workerId], references: [id])
  workerName    String
  project       String
  task          String
  spec          String
  qty           String
  // 计价引擎字段
  unitPrice     Float?       // 匹配定额单价（元/单位）
  totalValue    Float?       // 计算产值 = unitPrice * qty数值
  priceItemId   Int?         // 匹配的定额条目ID
  // 照片核验
  photoUrls     String[]     @default([])  // 多图（替代原 photoPath）
  gpsLat        Float?
  gpsLng        Float?
  verifiedBy    String?      // 班组长确认人ID
  verifiedAt    DateTime?
  // 状态
  status        String       @default("pending")  // pending | verified | rejected
  // 签证标记
  flagVisa      Boolean      @default(false)  // 超定额自动标记
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now()) @updatedAt
  corrections   Correction[]
}

// ─── 签证申请 ─────────────────────────────────────────────────────────────────

model Visa {
  id              Int      @id @default(autoincrement())
  serialNo        String?              // 序号，如 TJ-002
  type            String   @default("quantity")  // "quantity"=工程量签证 | "period"=工期签证
  title           String
  project         String               // 关联项目名
  projectCode     String?              // 关联项目编号
  submitter       String
  reason          String?              // 提出原因
  // 工程量签证专用
  amount          Float    @default(0)
  items           Json?                // 工程量明细条目数组
  // 工期签证专用
  daysExtended    Int?                 // 延期天数
  periodReason    String?              // 延期原因
  // 来源报量
  autoGenerated   Boolean  @default(false)
  sourceReportIds Int[]    @default([])
  // 多方签字状态
  contractorSign  String?              // 承包单位
  supervisorSign  String?              // 监理单位
  builderSign     String?              // 代建单位
  ownerSign       String?              // 建设单位
  // 附件
  pdfUrl          String?
  attachments     String[] @default([])
  extraData       Json?                // 扩展字段（自定义签证类型专用数据）
  status          String   @default("pending")  // pending | approved | rejected
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
}

// ─── 签证类型配置（可扩展，代替硬编码 TYPE_MAP） ──────────────────────────────

model VisaTypeConfig {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  color       String   @default("#60a5fa")
  bgColor     String   @default("rgba(59,130,246,0.12)")
  fieldSchema Json?    // 自定义字段定义
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

// ─── 施工作业票类型配置 ───────────────────────────────────────────────────────

model WorkTicketTypeConfig {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  name         String
  color        String   @default("#34d399")
  bgColor      String   @default("rgba(52,211,153,0.12)")
  defaultRisks String?  // 默认风险点（换行分隔）
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
}

// ─── 施工作业票 ───────────────────────────────────────────────────────────────

model WorkTicket {
  id              Int       @id @default(autoincrement())
  ticketNo        String?
  type            String    // "electrical" | "civil" | 自定义code
  projectName     String
  projectCode     String?
  workTeam        String
  riskLevel       String    @default("四级")
  workContent     String
  workLocation    String
  workerCount     Int       @default(1)
  plannedStart    DateTime?
  plannedEnd      DateTime?
  actualStart     DateTime?
  actualEnd       DateTime?
  foreman         String
  supervisor      String?
  assignments     String?
  memberChanges   String?
  risks           String?
  preconditions   Json?     // [{label, checked}]
  preControls     Json?     // [{label, checked}]
  fieldChanges    String?
  signerForeman   String?
  signerApprover  String?
  signerPermitter String?
  permitTime      DateTime?
  permitMethod    String?
  endTime         DateTime?
  note            String?
  status          String    @default("draft")  // draft | active | closed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
}

// ─── 异常纠偏 ─────────────────────────────────────────────────────────────────

model Correction {
  id         Int      @id @default(autoincrement())
  workerId   String
  worker     Worker   @relation(fields: [workerId], references: [id])
  workerName String
  original   String
  corrected  String
  reason     String
  reportId   Int?
  report     Report?  @relation(fields: [reportId], references: [id])
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

// ─── 工程项目（含 Geofencing 围栏配置） ──────────────────────────────────────

model Project {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  code        String   @unique
  budget      Float    @default(0)
  spent       Float    @default(0)
  profitRate  Float    @default(0)
  status      String   @default("active")
  // Geofencing
  centerLat   Float?
  centerLng   Float?
  geoRadius   Int?     @default(300)  // 围栏半径（米）
  createdAt   DateTime @default(now())
}

// ─── 审计追踪 ─────────────────────────────────────────────────────────────────

model AuditLog {
  id          Int      @id @default(autoincrement())
  tableName   String   // "Report" | "Visa" | "Correction" | "Project"
  recordId    Int
  field       String   // 修改的字段名
  oldValue    String?
  newValue    String?
  operatorId  String   @default("admin")
  action      String   @default("update")  // "update" | "delete"
  createdAt   DateTime @default(now())
}

// ─── 定额计价库 ───────────────────────────────────────────────────────────────

model PriceLibrary {
  id          Int         @id @default(autoincrement())
  name        String      // 如"湖南电网劳务定额2024"
  type        String      // "electrical" | "civil"
  projectCode String?     // 绑定项目编号，null=全局通用
  isActive    Boolean     @default(true)
  items       PriceItem[]
  createdAt   DateTime    @default(now())
}

model PriceItem {
  id          Int          @id @default(autoincrement())
  libraryId   Int
  library     PriceLibrary @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  code        String       // 工序编码
  name        String       // 如"电缆沟开挖"
  unit        String       // m³ / m / 个 / 根
  unitPrice   Float
  spec        String?      // 规格描述，如"断面0.6m²以内"
  keywords    String[]     @default([])  // 报量语音关键词匹配
  createdAt   DateTime     @default(now())
}

// ─── 基地费用（按工日分摊至项目） ────────────────────────────────────────────

model BaseCost {
  id        Int      @id @default(autoincrement())
  year      Int
  month     Int
  type      String   // "rent" | "food" | "housing" | "other"
  amount    Float
  note      String?
  createdAt DateTime @default(now())

  @@unique([year, month, type])
}

// ─── 材料库 ───────────────────────────────────────────────────────────────────

model MaterialLibrary {
  id          Int        @id @default(autoincrement())
  name        String     // 自定义库名，如"集团标准物料库2024"
  projectCode String?    // 绑定项目，null=全局
  isActive    Boolean    @default(true)
  items       Material[]
  createdAt   DateTime   @default(now())
}

model Material {
  id          Int             @id @default(autoincrement())
  libraryId   Int
  library     MaterialLibrary @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  code        String          // 集团物料编码
  name        String
  unit        String
  planQty     Float           @default(0)  // 图纸量
  usedQty     Float           @default(0)  // 现场消耗量
  unitCost    Float           @default(0)
  updatedAt   DateTime        @default(now()) @updatedAt
}

// ─── 工器具年检管理 ───────────────────────────────────────────────────────────

model Equipment {
  id             Int       @id @default(autoincrement())
  name           String    // 工器具名称
  code           String?   // 编号
  projectCode    String?   // 所属项目
  lastCheckDate  DateTime? // 上次年检日期
  nextCheckDate  DateTime? // 下次年检日期
  // "normal" | "warning"（15天内到期）| "overdue"（已超期）
  status         String    @default("normal")
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt
}
